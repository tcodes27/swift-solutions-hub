# -----------------------------------------------------------------------------
# Sprinter IT Hub — Environment configuration example
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and paste the deployed Google Apps Script
# Web App URL below. `.env.local` is git-ignored and stays on your machine.
#
#   cp .env.example .env.local
#
# After editing `.env.local`, restart the dev server so Vite picks up the
# new variable.
# -----------------------------------------------------------------------------

# Deployed Google Apps Script Web App endpoint.
# Example: https://script.google.com/macros/s/xxxxxxxxxxxxxxxxxxxxxxxx/exec
VITE_GOOGLE_APPS_SCRIPT_URL=
